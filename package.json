		"svelte": "^5.55.7",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.3"
	},
	"dependencies": {
		"js-yaml": "^4.1.1"
